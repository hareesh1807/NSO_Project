#!/bin/bash

if [ "$#" -lt 2 ]; then
  echo "Usage: ./cleanup <openrc> <tag>"
  exit 1
fi

OPENRC="$1"
TAG="$2"

echo "[INFO] Sourcing credentials from $OPENRC..."
source "$OPENRC"

echo "[INFO] Commencing teardown for environment: $TAG"

# 1. Delete Instances (Catches EVERYTHING starting with the tag)
NODES=$(openstack server list --name "^${TAG}_" -f value -c ID)
if [ -n "$NODES" ]; then
    echo "[INFO] Terminating compute instances..."
    echo "$NODES" | xargs -r openstack server delete || true
    echo "[WAIT] Allowing Nova backend 15 seconds to release quotas..."
    sleep 15
else
    echo "[INFO] No running instances found for tag $TAG."
fi

# 2. Delete Unused Floating IPs
echo "[INFO] Releasing orphaned Floating IPs..."
openstack floating ip list --status DOWN -f value -c ID | xargs -r openstack floating ip delete >/dev/null 2>&1 || true

# 3. Destroy Network Stack
echo "[INFO] Destroying networking components and security groups..."
openstack security group delete "${TAG}_sg" >/dev/null 2>&1 || true
openstack router remove subnet "${TAG}_router" "${TAG}_subnet" >/dev/null 2>&1 || true
openstack router delete "${TAG}_router" >/dev/null 2>&1 || true
openstack subnet delete "${TAG}_subnet" >/dev/null 2>&1 || true
openstack network delete "${TAG}_network" >/dev/null 2>&1 || true
openstack keypair delete "${TAG}_key" >/dev/null 2>&1 || true

echo "[SUCCESS] Environment $TAG has been completely sanitized."